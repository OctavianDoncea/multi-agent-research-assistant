# LLM routing
LLM_PRIMARY=groq
LLM_FALLBACK=ollama

# Groq (OpenAI-compatible)
GROQ_API_KEY=put_your_groq_key_here
GROQ_MODEL_PLANNER=openai/gpt-oss-20b
GROQ_MODEL_SUMMARIZER=llama-3.1-8b-instant
GROQ_MODEL_FACTCHECKER=openai/gpt-oss-20b

# Optional
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local OpenAI-compatible)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1

# Search / extraction controls
SEARCH_PROVIDER=duckduckgo
MAX_SUBQUESTIONS=3
MAX_SEARCH_RESULTS=6
MAX_PAGES_PER_SUBQUESTION=2

# Content limits
MAX_CHARS_PER_PAGE=8000
MAX_TOTAL_SOURCE_CHARS=24000

# API server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000